{
  "name": "@portal-corinthians/api",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "lint": "eslint .",
    "test": "vitest run",
