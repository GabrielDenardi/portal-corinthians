generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CategorySlug {
  profissional
  feminino
  base
  mercado
  torcida
  clube
}

enum MatchStatusTone {
  default
  alert
  success
  warning
}

enum SyncStatus {
  running
  succeeded
  failed
}

model ArticleSource {
  id        String    @id @default(cuid())
  name      String
  baseUrl   String?
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name, baseUrl])
}

model Article {
  id           String        @id @default(cuid())
  externalId   String?
  slug         String        @unique
  title        String
  dek          String
  summary      String
  body         Json
  originalUrl  String        @unique
  canonicalUrl String?
  imageUrl     String?
  imageAlt     String?
  category     CategorySlug
  publishedAt  DateTime
  readTime     String
  badge        String?
  badgeLabel   String?
  tone         MatchStatusTone @default(default)
  featuredRank Int           @default(0)
  isActive     Boolean       @default(true)
  viewCount    Int           @default(0)
  sourceId     String
  source       ArticleSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  syncedAt     DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  views        ArticleView[]

  @@index([category, publishedAt(sort: Desc)])
  @@index([viewCount(sort: Desc)])
}

model Team {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  name           String
  normalizedName String   @unique
  shortName      String?
  badgeUrl       String?
  country        String?
  sport          String?
  alternateNames Json?
  sourceUpdatedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  homeMatches    Match[]  @relation("HomeTeam")
  awayMatches    Match[]  @relation("AwayTeam")
}

model Match {
  id          String          @id @default(cuid())
  externalId  String?         @unique
  competition String
  round       String
  venue       String
  kickOff     DateTime
  broadcast   String
  note        String
  statusLabel String
  statusTone  MatchStatusTone @default(default)
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team            @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam    Team            @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  syncedAt    DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kickOff(sort: Asc)])
}

model ArticleView {
  id           String   @id @default(cuid())
  articleId    String
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  clientKey    String
  windowBucket String
  createdAt    DateTime @default(now())

  @@unique([articleId, clientKey, windowBucket])
  @@index([createdAt])
}

model SyncRun {
  id               String     @id @default(cuid())
  jobName          String
  status           SyncStatus
  message          String?
  recordsProcessed Int        @default(0)
  startedAt        DateTime   @default(now())
  finishedAt       DateTime?
  createdAt        DateTime   @default(now())

  @@index([jobName, startedAt(sort: Desc)])
}
